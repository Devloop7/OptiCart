# ─── Database ───────────────────────────────────────────────
# PostgreSQL connection string. For local dev with docker-compose:
DATABASE_URL=postgresql://opticart:opticart_dev@localhost:5432/opticart

# ─── Redis ──────────────────────────────────────────────────
# Redis URL for BullMQ queues, caching, and rate limiting
REDIS_URL=redis://localhost:6379

# ─── NextAuth ───────────────────────────────────────────────
# The canonical URL of your app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── OAuth Providers ────────────────────────────────────────
# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Credential Vault Encryption ────────────────────────────
# 32-byte key as 64-character hex string
# Generate with: openssl rand -hex 32
VAULT_ENCRYPTION_KEY=

# ─── AI / LLM (Phase 1 optional) ────────────────────────────
# OpenAI API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Security ───────────────────────────────────────────────
# Max failed login attempts before account lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
# Lockout duration in minutes
LOCKOUT_DURATION_MINUTES=30

# ─── Watcher Configuration ──────────────────────────────────
# Default check interval in minutes
WATCHER_DEFAULT_INTERVAL=60
# Price change threshold (%) that triggers order pause
PRICE_ALERT_THRESHOLD=5
# Max concurrent watcher jobs
WATCHER_CONCURRENCY=5

# ─── Proxy (Phase 2) ────────────────────────────────────────
# PROXY_PROVIDER_URL=
# PROXY_API_KEY=
