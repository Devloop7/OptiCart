generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────
// ENUMS
// ──────────────────────────────────────

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum StorePlatform {
  SHOPIFY
  WOOCOMMERCE
  EBAY
  TIKTOK_SHOP
}

enum SupplierPlatform {
  ALIEXPRESS
  CJ_DROPSHIPPING
  ALIBABA_1688
  CUSTOM
}

enum ProductStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  ORDERED_FROM_SUPPLIER
  SHIPPED
  DELIVERED
  CANCELLED
  ERROR
}

enum AutomationType {
  STOCK_SYNC
  PRICE_SYNC
}

enum AutomationStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum RunStatus {
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

enum PlanTier {
  FREE
  STARTER
  PRO
  SCALE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

// ──────────────────────────────────────
// AUTH (NextAuth compatible)
// ──────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  hashedPassword  String?
  failedLoginAttempts Int   @default(0)
  lockedUntil     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ──────────────────────────────────────
// WORKSPACE & TEAM (multi-tenant)
// ──────────────────────────────────────

model Workspace {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  currency        String   @default("USD")
  timezone        String   @default("UTC")
  settings        Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships     Membership[]
  stores          Store[]
  suppliers       WorkspaceSupplier[]
  products        Product[]
  orders          StoreOrder[]
  pricingRules    PricingRule[]
  automationRules AutomationRule[]
  winningProducts WinningProduct[]
  subscription    Subscription?
  usageRecords    UsageRecord[]

  @@map("workspaces")
}

model Membership {
  id          String     @id @default(cuid())
  userId      String
  workspaceId String
  role        MemberRole @default(MEMBER)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("memberships")
}

// ──────────────────────────────────────
// STORES
// ──────────────────────────────────────

model Store {
  id           String        @id @default(cuid())
  workspaceId  String
  name         String
  platform     StorePlatform
  domain       String?
  accessToken  String?       @db.Text
  isActive     Boolean       @default(true)
  lastSyncAt   DateTime?
  settings     Json          @default("{}")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  workspace    Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  storeLinks   ProductStoreLink[]
  orders       StoreOrder[]
  pricingRules PricingRule[]

  @@index([workspaceId])
  @@map("stores")
}

// ──────────────────────────────────────
// SUPPLIERS & ALIEXPRESS SOURCING
// ──────────────────────────────────────

model WorkspaceSupplier {
  id          String           @id @default(cuid())
  workspaceId String
  platform    SupplierPlatform
  name        String
  config      Json             @default("{}")
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  supplierProducts SupplierProduct[]

  @@index([workspaceId])
  @@map("workspace_suppliers")
}

model SupplierProduct {
  id                String    @id @default(cuid())
  supplierId        String
  externalId        String
  sourceUrl         String
  title             String
  description       String?   @db.Text
  images            Json      @default("[]")
  rating            Decimal?  @db.Decimal(3, 2)
  totalOrders       Int?
  shippingOptions   Json      @default("[]")
  rawData           Json      @default("{}")
  fetchedAt         DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  supplier          WorkspaceSupplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  variants          SupplierVariant[]
  products          Product[]

  @@unique([supplierId, externalId])
  @@index([supplierId])
  @@map("supplier_products")
}

model SupplierVariant {
  id                String  @id @default(cuid())
  supplierProductId String
  externalId        String
  name              String
  attributes        Json    @default("{}")
  price             Decimal @db.Decimal(10, 2)
  stock             Int     @default(0)
  image             String?
  sku               String?

  supplierProduct   SupplierProduct  @relation(fields: [supplierProductId], references: [id], onDelete: Cascade)
  variantMappings   ProductVariant[]

  @@unique([supplierProductId, externalId])
  @@index([supplierProductId])
  @@map("supplier_variants")
}

// ──────────────────────────────────────
// PRODUCTS & CATALOG
// ──────────────────────────────────────

model Product {
  id                String        @id @default(cuid())
  workspaceId       String
  supplierProductId String?
  title             String
  description       String?       @db.Text
  images            Json          @default("[]")
  tags              String[]      @default([])
  category          String?
  status            ProductStatus @default(DRAFT)
  stockSyncEnabled  Boolean       @default(true)
  priceSyncEnabled  Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  workspace         Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  supplierProduct   SupplierProduct?  @relation(fields: [supplierProductId], references: [id], onDelete: SetNull)
  variants          ProductVariant[]
  storeLinks        ProductStoreLink[]
  pricingRules      PricingRule[]
  orderItems        OrderItem[]

  @@index([workspaceId])
  @@index([status])
  @@index([supplierProductId])
  @@map("products")
}

model ProductVariant {
  id                String  @id @default(cuid())
  productId         String
  supplierVariantId String?
  name              String
  sku               String?
  supplierCost      Decimal @db.Decimal(10, 2)
  retailPrice       Decimal @db.Decimal(10, 2)
  stock             Int     @default(0)
  image             String?
  isActive          Boolean @default(true)

  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplierVariant  SupplierVariant? @relation(fields: [supplierVariantId], references: [id], onDelete: SetNull)
  orderItems       OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model ProductStoreLink {
  id                String  @id @default(cuid())
  productId         String
  storeId           String
  externalProductId String?
  externalUrl       String?
  isPushed          Boolean @default(false)
  lastPushedAt      DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([productId, storeId])
  @@index([storeId])
  @@map("product_store_links")
}

// ──────────────────────────────────────
// PRICING RULES
// ──────────────────────────────────────

model PricingRule {
  id           String  @id @default(cuid())
  workspaceId  String
  storeId      String?
  productId    String?
  name         String
  multiplier   Decimal @db.Decimal(5, 2) @default(2.0)
  fixedAddon   Decimal @db.Decimal(10, 2) @default(0)
  minMarginPct Decimal @db.Decimal(5, 2) @default(20)
  maxPrice     Decimal? @db.Decimal(10, 2)
  isDefault    Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  store     Store?    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("pricing_rules")
}

// ──────────────────────────────────────
// ORDERS & FULFILLMENT
// ──────────────────────────────────────

model StoreOrder {
  id              String      @id @default(cuid())
  workspaceId     String
  storeId         String
  externalOrderId String?
  status          OrderStatus @default(NEW)
  customerName    String?
  customerEmail   String?
  shippingAddress Json?
  totalAmount     Decimal     @db.Decimal(10, 2) @default(0)
  totalProfit     Decimal     @db.Decimal(10, 2) @default(0)
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  store          Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items          OrderItem[]
  supplierOrders SupplierOrder[]
  logs           OrderLog[]

  @@index([workspaceId])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
  @@map("store_orders")
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String
  variantId       String?
  quantity        Int     @default(1)
  supplierCost    Decimal @db.Decimal(10, 2)
  sellingPrice    Decimal @db.Decimal(10, 2)
  profit          Decimal @db.Decimal(10, 2)

  order   StoreOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_items")
}

model SupplierOrder {
  id                String      @id @default(cuid())
  orderId           String
  supplierOrderId   String?
  trackingNumber    String?
  trackingUrl       String?
  status            OrderStatus @default(NEW)
  placedAt          DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  cost              Decimal     @db.Decimal(10, 2) @default(0)
  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  order StoreOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("supplier_orders")
}

model OrderLog {
  id        String   @id @default(cuid())
  orderId   String
  action    String
  details   String?  @db.Text
  createdAt DateTime @default(now())

  order StoreOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_logs")
}

// ──────────────────────────────────────
// AUTOMATION ENGINE
// ──────────────────────────────────────

model AutomationRule {
  id              String           @id @default(cuid())
  workspaceId     String
  type            AutomationType
  name            String
  status          AutomationStatus @default(ACTIVE)
  config          Json             @default("{}")
  frequencyMinutes Int             @default(60)
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  runs      AutomationRun[]

  @@index([workspaceId])
  @@index([status, nextRunAt])
  @@map("automation_rules")
}

model AutomationRun {
  id          String    @id @default(cuid())
  ruleId      String
  status      RunStatus @default(RUNNING)
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  itemsChecked Int      @default(0)
  itemsUpdated Int      @default(0)
  errorMessage String?  @db.Text
  createdAt   DateTime  @default(now())

  rule AutomationRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  logs AutomationLog[]

  @@index([ruleId, createdAt])
  @@map("automation_runs")
}

model AutomationLog {
  id        String   @id @default(cuid())
  runId     String
  level     String   @default("info")
  message   String
  data      Json?
  createdAt DateTime @default(now())

  run AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("automation_logs")
}

// ──────────────────────────────────────
// AI WINNING PRODUCTS
// ──────────────────────────────────────

model WinningProduct {
  id              String   @id @default(cuid())
  workspaceId     String
  sourceUrl       String
  title           String
  images          Json     @default("[]")
  supplierPrice   Decimal  @db.Decimal(10, 2)
  estimatedProfit Decimal  @db.Decimal(10, 2)
  winningScore    Int      @default(0)
  scoreBreakdown  Json     @default("{}")
  niche           String?
  targetCountries String[] @default([])
  aiInsights      Json     @default("{}")
  isImported      Boolean  @default(false)
  importedProductId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([winningScore])
  @@map("winning_products")
}

// ──────────────────────────────────────
// BILLING & PLANS
// ──────────────────────────────────────

model Plan {
  id              String   @id @default(cuid())
  tier            PlanTier @unique
  name            String
  stripePriceId   String?
  monthlyPrice    Decimal  @db.Decimal(10, 2) @default(0)
  maxProducts     Int      @default(100)
  maxOrdersMonth  Int      @default(50)
  maxStores       Int      @default(1)
  maxAiRequests   Int      @default(0)
  automationFreq  Int      @default(360)
  features        Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                  String             @id @default(cuid())
  workspaceId         String             @unique
  planId              String
  stripeCustomerId    String?
  stripeSubscriptionId String?
  status              SubscriptionStatus @default(ACTIVE)
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id])

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model UsageRecord {
  id          String   @id @default(cuid())
  workspaceId String
  month       String
  products    Int      @default(0)
  orders      Int      @default(0)
  aiRequests  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, month])
  @@map("usage_records")
}

// ──────────────────────────────────────
// SYSTEM
// ──────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  workspaceId String?
  userId      String?
  action      String
  details     String?  @db.Text
  severity    String   @default("info")
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([severity])
  @@map("activity_logs")
}
